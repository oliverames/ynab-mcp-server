{
  "mcpServers": {
    "ynab-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@oliverames/mcp-server-for-ynab@latest"
      ],
      "env": {
        "YNAB_ALLOW_WRITES": "1"
      },
      "env_vars": [
        "YNAB_API_TOKEN",
        "YNAB_BUDGET_ID",
        "YNAB_OP_PATH",
        "OP_SERVICE_ACCOUNT_TOKEN"
      ]
    }
  }
}
